@model DesignPatterns.CQRS.CQRSDesignPattern.Results.GetProductUpdateQueryResult
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RETRO MARKET - Update Product</title>

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Courier+Prime:wght@400;700&family=Special+Elite&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --vintage-cream: #f4e8d0;
            --vintage-brown: #8b5a3c;
            --vintage-orange: #d97142;
            --vintage-teal: #5a9a8e;
            --vintage-navy: #2c4251;
            --vintage-red: #c84843;
            --vintage-purple: #8b5f9d;
            --paper-texture: #faf5eb;
        }

        body {
            font-family: 'Courier Prime', monospace;
            background: var(--paper-texture);
            color: var(--vintage-navy);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
        }

            /* Paper Texture */
            body::before {
                content: '';
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background-image: repeating-linear-gradient(0deg, rgba(0,0,0,.03) 0px, transparent 1px, transparent 2px, rgba(0,0,0,.03) 3px), repeating-linear-gradient(90deg, rgba(0,0,0,.03) 0px, transparent 1px, transparent 2px, rgba(0,0,0,.03) 3px);
                pointer-events: none;
                z-index: 9999;
            }

        .form-container {
            max-width: 700px;
            width: 100%;
            background: var(--vintage-cream);
            border: 10px solid var(--vintage-navy);
            box-shadow: inset 0 0 0 4px var(--vintage-purple), 15px 15px 0 rgba(0,0,0,0.3);
            position: relative;
            padding: 50px 40px;
        }

        /* Corner Decorations */
        .corner-decoration {
            position: absolute;
            width: 50px;
            height: 50px;
            border: 5px solid var(--vintage-purple);
        }

            .corner-decoration.tl {
                top: 20px;
                left: 20px;
                border-right: none;
                border-bottom: none;
            }

            .corner-decoration.tr {
                top: 20px;
                right: 20px;
                border-left: none;
                border-bottom: none;
            }

            .corner-decoration.bl {
                bottom: 20px;
                left: 20px;
                border-right: none;
                border-top: none;
            }

            .corner-decoration.br {
                bottom: 20px;
                right: 20px;
                border-left: none;
                border-top: none;
            }

        /* Stamp */
        .stamp {
            position: absolute;
            top: -20px;
            right: -20px;
            width: 100px;
            height: 100px;
            border: 4px solid var(--vintage-purple);
            border-radius: 50%;
            background: var(--vintage-cream);
            display: flex;
            align-items: center;
            justify-content: center;
            transform: rotate(15deg);
            box-shadow: 3px 3px 10px rgba(0,0,0,0.2);
        }

        .stamp-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.2rem;
            color: var(--vintage-purple);
            text-align: center;
            line-height: 1.2;
            letter-spacing: 1px;
        }

        /* Header */
        .form-header {
            text-align: center;
            margin-bottom: 40px;
            padding-bottom: 30px;
            border-bottom: 4px double var(--vintage-navy);
            position: relative;
        }

            .form-header::before {
                content: '✎';
                position: absolute;
                top: -15px;
                left: 50%;
                transform: translateX(-50%);
                font-size: 2rem;
                color: var(--vintage-purple);
            }

        .product-id-display {
            font-family: 'Special Elite', cursive;
            font-size: 0.9rem;
            color: var(--vintage-brown);
            letter-spacing: 2px;
            margin-bottom: 10px;
        }

        .form-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 3.5rem;
            color: var(--vintage-navy);
            letter-spacing: 6px;
            text-shadow: 3px 3px 0 rgba(0,0,0,0.1);
            margin-bottom: 10px;
        }

        .form-subtitle {
            font-family: 'Special Elite', cursive;
            font-size: 1.1rem;
            color: var(--vintage-brown);
            letter-spacing: 3px;
            text-transform: uppercase;
        }

        /* Form Styling */
        .form-group {
            margin-bottom: 30px;
            position: relative;
        }

        .form-label {
            display: block;
            font-family: 'Special Elite', cursive;
            font-size: 0.9rem;
            color: var(--vintage-brown);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            font-weight: 700;
        }

            .form-label::before {
                content: '◆ ';
                color: var(--vintage-purple);
            }

        .form-control {
            width: 100%;
            padding: 15px 20px;
            font-family: 'Courier Prime', monospace;
            font-size: 1.1rem;
            background: white;
            border: 4px solid var(--vintage-navy);
            color: var(--vintage-navy);
            transition: all 0.3s ease;
            box-shadow: 4px 4px 0 rgba(0,0,0,0.1);
        }

            .form-control:focus {
                outline: none;
                border-color: var(--vintage-purple);
                box-shadow: 4px 4px 0 rgba(0,0,0,0.2), inset 0 0 0 2px var(--vintage-purple);
                transform: translateY(-2px);
            }

            .form-control::placeholder {
                color: rgba(44, 66, 81, 0.4);
                font-style: italic;
            }

        /* Hidden ID Input */
        input[type="hidden"] {
            display: none;
        }

        /* Input Icons */
        .input-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            font-size: 1.2rem;
            color: var(--vintage-brown);
            opacity: 0.5;
        }

        /* Buttons */
        .button-group {
            display: flex;
            gap: 15px;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 4px double var(--vintage-navy);
        }

        .btn {
            flex: 1;
            padding: 18px 30px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.4rem;
            letter-spacing: 3px;
            border: 5px solid var(--vintage-navy);
            cursor: pointer;
            transition: all 0.2s ease;
            text-decoration: none;
            text-align: center;
            display: inline-block;
            box-shadow: 6px 6px 0 rgba(0,0,0,0.2);
            position: relative;
        }

            .btn:hover {
                transform: translate(3px, 3px);
                box-shadow: 3px 3px 0 rgba(0,0,0,0.2);
            }

        .btn-update {
            background: linear-gradient(135deg, var(--vintage-purple), #9b7bb5);
            color: var(--vintage-cream);
        }

            .btn-update::before {
                content: '✎ ';
            }

        .btn-cancel {
            background: var(--vintage-teal);
            color: white;
        }

            .btn-cancel::before {
                content: '← ';
            }

        /* Current Values Display */
        .current-values {
            background: white;
            padding: 20px;
            border: 3px dashed var(--vintage-brown);
            margin-bottom: 30px;
        }

        .current-values-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            color: var(--vintage-brown);
            letter-spacing: 2px;
            margin-bottom: 15px;
        }

        .current-item {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid #eee;
        }

            .current-item:last-child {
                border-bottom: none;
            }

        .current-label {
            font-weight: 700;
            color: var(--vintage-brown);
            font-size: 0.9rem;
        }

        .current-value {
            color: var(--vintage-navy);
            font-weight: 600;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .form-container {
                padding: 40px 25px;
                border-width: 6px;
            }

            .form-title {
                font-size: 2.5rem;
            }

            .button-group {
                flex-direction: column;
            }

            .stamp {
                top: -15px;
                right: -15px;
                width: 80px;
                height: 80px;
            }

            .stamp-text {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="form-container">
        <!-- Corner Decorations -->
        <div class="corner-decoration tl"></div>
        <div class="corner-decoration tr"></div>
        <div class="corner-decoration bl"></div>
        <div class="corner-decoration br"></div>

        <!-- Stamp -->
        <div class="stamp">
            <div class="stamp-text">UPDATE<br>FORM</div>
        </div>

        <!-- Header -->
        <div class="form-header">
            <div class="product-id-display">PRODUCT NO. @Model.ProductId</div>
            <h1 class="form-title">UPDATE PRODUCT</h1>
            <p class="form-subtitle">★ Modify Product Information ★</p>
        </div>

        <!-- Current Values Display (Optional) -->
        @if (Model != null)
        {
            <div class="current-values">
                <div class="current-values-title">📋 Current Information</div>
                <div class="current-item">
                    <span class="current-label">Name:</span>
                    <span class="current-value">@Model.Name</span>
                </div>
                <div class="current-item">
                    <span class="current-label">Stock:</span>
                    <span class="current-value">@Model.Stock units</span>
                </div>
                <div class="current-item">
                    <span class="current-label">Price:</span>
                    <span class="current-value">$@Model.Price</span>
                </div>
            </div>
        }

        <!-- Form -->
        <form method="post" asp-action="UpdateProduct" asp-controller="Default">
            <!-- Hidden ID -->
            <input type="hidden" asp-for="ProductId" />

            <div class="form-group">
                <label class="form-label" asp-for="Name">Product Name</label>
                <div class="input-wrapper">
                    <input type="text"
                           class="form-control"
                           asp-for="Name"
                           placeholder="Enter new product name..."
                           required
                           autofocus />
                    <span class="input-icon">📝</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Stock">Stock Quantity</label>
                <div class="input-wrapper">
                    <input type="number"
                           class="form-control"
                           asp-for="Stock"
                           placeholder="Update stock count..."
                           min="0"
                           required />
                    <span class="input-icon">📦</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Price">Product Price</label>
                <div class="input-wrapper">
                    <input type="number"
                           class="form-control"
                           asp-for="Price"
                           step="0.01"
                           placeholder="Update price in USD..."
                           min="0"
                           required />
                    <span class="input-icon">💰</span>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Description">Product Description</label>
                <div class="input-wrapper">
                    <input type="text"
                           class="form-control"
                           asp-for="Description"
                           placeholder="Update product description..."
                           required />
                    <span class="input-icon">✎</span>
                </div>
            </div>

            <div class="button-group">
                <a href="/Default/Index/" class="btn btn-cancel">
                    Cancel
                </a>
                <button type="submit" class="btn btn-update">
                    Update Product
                </button>
            </div>
        </form>
    </div>
</body>
</html>
