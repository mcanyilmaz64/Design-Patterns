@model DesignPatterns.CQRS.CQRSDesignPattern.Results.GetProductByIDQueryResult
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RETRO MARKET - Product Details</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Courier+Prime:wght@400;700&family=Special+Elite&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --vintage-cream: #f4e8d0;
            --vintage-brown: #8b5a3c;
            --vintage-orange: #d97142;
            --vintage-teal: #5a9a8e;
            --vintage-navy: #2c4251;
            --vintage-red: #c84843;
            --vintage-purple: #8b5f9d;
            --paper-texture: #faf5eb;
        }

        body {
            font-family: 'Courier Prime', monospace;
            background: var(--paper-texture);
            color: var(--vintage-navy);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
            position: relative;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                repeating-linear-gradient(0deg, rgba(0,0,0,.03) 0px, transparent 1px, transparent 2px, rgba(0,0,0,.03) 3px),
                repeating-linear-gradient(90deg, rgba(0,0,0,.03) 0px, transparent 1px, transparent 2px, rgba(0,0,0,.03) 3px);
            pointer-events: none;
            z-index: 9999;
        }

        .detail-container {
            max-width: 900px;
            width: 100%;
            background: var(--vintage-cream);
            border: 10px solid var(--vintage-navy);
            box-shadow: 
                inset 0 0 0 5px var(--vintage-orange),
                20px 20px 0 rgba(0,0,0,0.3);
            position: relative;
        }

        /* Stamp - Top Right */
        .stamp {
            position: absolute;
            top: -25px;
            right: -25px;
            width: 120px;
            height: 120px;
            border: 5px solid var(--vintage-red);
            border-radius: 50%;
            background: var(--vintage-cream);
            display: flex;
            align-items: center;
            justify-content: center;
            transform: rotate(15deg);
            box-shadow: 5px 5px 15px rgba(0,0,0,0.3);
            z-index: 10;
        }

        .stamp-text {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            color: var(--vintage-red);
            text-align: center;
            line-height: 1.2;
            letter-spacing: 1px;
        }

        /* Header */
        .detail-header {
            background: linear-gradient(135deg, var(--vintage-orange), var(--vintage-red));
            padding: 50px 40px;
            text-align: center;
            position: relative;
            border-bottom: 6px solid var(--vintage-navy);
        }

        .detail-header::before {
            content: '◆ ◆ ◆';
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 1.5rem;
            color: var(--vintage-cream);
            letter-spacing: 15px;
        }

        .product-id-large {
            font-family: 'Special Elite', cursive;
            font-size: 1.2rem;
            color: var(--vintage-cream);
            letter-spacing: 3px;
            margin-bottom: 15px;
        }

        .product-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 4rem;
            color: var(--vintage-cream);
            letter-spacing: 8px;
            text-shadow: 
                4px 4px 0 var(--vintage-navy),
                8px 8px 0 rgba(0,0,0,0.3);
            line-height: 1;
        }

        /* Body */
        .detail-body {
            padding: 50px 40px;
        }

        .info-section {
            margin-bottom: 40px;
        }

        .section-title {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            color: var(--vintage-navy);
            letter-spacing: 4px;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 4px double var(--vintage-brown);
            position: relative;
        }

        .section-title::before {
            content: '★';
            margin-right: 10px;
            color: var(--vintage-red);
        }

        /* Detail Grid */
        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin-bottom: 40px;
        }

        .detail-item {
            background: white;
            padding: 25px;
            border: 4px solid var(--vintage-navy);
            position: relative;
            box-shadow: 5px 5px 0 rgba(0,0,0,0.1);
        }

        .detail-item::before {
            content: '';
            position: absolute;
            top: -3px;
            left: -3px;
            right: -3px;
            bottom: -3px;
            border: 2px dashed var(--vintage-orange);
        }

        .detail-label {
            font-family: 'Special Elite', cursive;
            font-size: 0.85rem;
            color: var(--vintage-brown);
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 10px;
            display: block;
        }

        .detail-value {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2.5rem;
            color: var(--vintage-navy);
            letter-spacing: 2px;
        }

        .price-highlight {
            background: var(--vintage-red);
            color: var(--vintage-cream);
            padding: 15px;
            border: 4px solid var(--vintage-navy);
            box-shadow: 4px 4px 0 rgba(0,0,0,0.2);
        }

        .stock-highlight {
            background: var(--vintage-teal);
            color: white;
            padding: 15px;
            border: 4px solid var(--vintage-navy);
            box-shadow: 4px 4px 0 rgba(0,0,0,0.2);
        }

        .stock-highlight.low {
            background: var(--vintage-red);
        }

        /* Description Box */
        .description-box {
            background: white;
            padding: 30px;
            border: 4px solid var(--vintage-navy);
            box-shadow: 5px 5px 0 rgba(0,0,0,0.1);
            position: relative;
        }

        .description-box::before {
            content: '';
            position: absolute;
            top: -3px;
            left: -3px;
            right: -3px;
            bottom: -3px;
            border: 2px dashed var(--vintage-purple);
        }

        .description-text {
            font-size: 1.2rem;
            line-height: 1.8;
            color: var(--vintage-navy);
            text-align: justify;
        }

        /* Status Badge */
        .status-section {
            text-align: center;
            padding: 30px;
            background: white;
            border: 4px dashed var(--vintage-brown);
            margin-bottom: 40px;
        }

        .status-badge {
            display: inline-block;
            padding: 15px 40px;
            font-family: 'Bebas Neue', sans-serif;
            font-size: 2rem;
            letter-spacing: 4px;
            border: 4px solid var(--vintage-navy);
            box-shadow: 4px 4px 0 rgba(0,0,0,0.2);
        }

        .status-active {
            background: var(--vintage-teal);
            color: white;
        }

        .status-inactive {
            background: #ccc;
            color: #666;
        }

        /* Footer Buttons */
        .detail-footer {
            padding: 30px 40px;
            background: var(--vintage-navy);
            border-top: 6px solid var(--vintage-orange);
            display: flex;
            gap: 15px;
        }

        .btn {
            flex: 1;
            padding: 18px;
            border: 4px solid var(--vintage-cream);
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.3rem;
            letter-spacing: 3px;
            cursor: pointer;
            text-decoration: none;
            text-align: center;
            transition: all 0.2s ease;
            color: var(--vintage-cream);
            box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
        }

        .btn:hover {
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0 rgba(0,0,0,0.3);
        }

        .btn-back {
            background: var(--vintage-teal);
        }

        .btn-edit {
            background: var(--vintage-purple);
        }

        .btn-delete {
            background: var(--vintage-red);
        }

        /* Corner Decorations */
        .corner-decoration {
            position: absolute;
            width: 60px;
            height: 60px;
            border: 6px solid var(--vintage-red);
        }

        .corner-decoration.tl { top: 30px; left: 30px; border-right: none; border-bottom: none; }
        .corner-decoration.tr { top: 30px; right: 30px; border-left: none; border-bottom: none; }
        .corner-decoration.bl { bottom: 30px; left: 30px; border-right: none; border-top: none; }
        .corner-decoration.br { bottom: 30px; right: 30px; border-left: none; border-top: none; }

        /* Responsive */
        @@media (max-width: 768px) {
            .detail-container {
                border-width: 6px;
            }

            .product-title {
                font-size: 2.5rem;
            }

            .detail-grid {
                grid-template-columns: 1fr;
            }

            .detail-footer {
                flex-direction: column;
            }

            .detail-body {
                padding: 30px 25px;
            }

            .stamp {
                width: 90px;
                height: 90px;
                top: -20px;
                right: -20px;
            }

            .stamp-text {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="detail-container">
        <!-- Corner Decorations -->
        <div class="corner-decoration tl"></div>
        <div class="corner-decoration tr"></div>
        <div class="corner-decoration bl"></div>
        <div class="corner-decoration br"></div>

        <!-- Stamp -->
        <div class="stamp">
            <div class="stamp-text">PRODUCT<br>DETAILS</div>
        </div>

        <!-- Header -->
        <div class="detail-header">
            <div class="product-id-large">PRODUCT NO. @Model.ProductId</div>
            <h1 class="product-title">@Model.Name</h1>
        </div>

        <!-- Body -->
        <div class="detail-body">
            <!-- Price & Stock Section -->
            <div class="info-section">
                <h2 class="section-title">Pricing & Inventory</h2>
                <div class="detail-grid">
                    <div class="detail-item price-highlight">
                        <span class="detail-label">Unit Price</span>
                        <div class="detail-value">$@Model.Price</div>
                    </div>
                    <div class="detail-item stock-highlight @(Model.Stock < 20 ? "low" : "")">
                        <span class="detail-label">Available Stock</span>
                        <div class="detail-value">@Model.Stock</div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Footer -->
        <div class="detail-footer">
            <a href="/Default/Index/" class="btn btn-back">
                ← Back to List
            </a>
            <a href="/Default/UpdateProduct/@Model.ProductId" class="btn btn-edit">
                ✎ Edit Product
            </a>
            <a href="/Default/DeleteProduct/@Model.ProductId" 
               class="btn btn-delete"
               onclick="return confirm('Are you sure you want to delete this product?')">
                ✕ Delete Product
            </a>
        </div>
    </div>
</body>
</html>
